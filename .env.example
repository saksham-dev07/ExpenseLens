# Advanced OCR Receipt Scanner - Environment Variables

# FLASK Configuration
SECRET_KEY=your_generated_secret_key_here
JWT_SECRET_KEY=your_generated_jwt_secret_key_here
FLASK_DEBUG=False
PORT=5000

# Firebase Configuration
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
GOOGLE_APPLICATION_CREDENTIALS=firebase_credentials.json

# Gemini AI (Required for intelligent parsing)
GEMINI_API_KEY=your_gemini_api_key_here

# Tabscanner API (Alternative OCR)
TABSCANNER_API_KEY=your_tabscanner_api_key_here

# OCR Configuration
OCR_CONFIDENCE_THRESHOLD=30
